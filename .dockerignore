# Docker build context = the REPO ROOT (see showcase/config/deploy.yml).
#
# The showcase depends on the engine via `gem "current_scope", path: ".."`,
# which lives ABOVE showcase/, so a showcase-scoped context can't `bundle
# install`. The context is therefore the repo root, and Docker only honors a
# .dockerignore at the context root — so THIS file (not showcase/.dockerignore,
# which is now inert) governs what is sent to the daemon and baked into layers.
# The Rails master key and .git history must never bake into an image layer.

# --- Repo-root VCS / tooling / secrets ---
.git/
.gitignore
.env*
node_modules/

# --- Engine (gem) build/test artifacts ---
# The gem source under app/ config/ db/ lib/ is COPYed explicitly by the
# Dockerfile; none of the following is needed in the image.
/test/
/tmp/
/storage/
*.gem

# --- The old demo app is not part of the showcase image ---
/demo/

# --- Showcase (Rails host app) ---
# Secrets: never bake the master key or credential keys into a layer.
showcase/config/master.key
showcase/config/credentials/*.key

# VCS / bundler / node noise
showcase/.git
showcase/.env*
showcase/.bundle
showcase/node_modules/

# Logs, tempfiles, pidfiles — keep the .keep so the dir exists for the runtime user.
showcase/log/*
!showcase/log/.keep
showcase/tmp/*
!showcase/tmp/.keep
showcase/tmp/pids/*
!showcase/tmp/pids/.keep

# Storage (SQLite DBs + Active Storage uploads) lives on the Kamal named volume,
# never in the image. Keep .keep so the dir exists and the fresh volume inherits
# its (rails:rails) ownership on first mount.
showcase/storage/*
!showcase/storage/.keep
showcase/tmp/storage/*
!showcase/tmp/storage/.keep

# Assets are precompiled inside the image; don't ship local dev copies.
showcase/app/assets/builds/*
!showcase/app/assets/builds/.keep
showcase/public/assets
