# frozen_string_literal: true

require "set" # Enumerable#to_set — explicit so a bare boot can't NoMethodError

# Generated by the current-scope-migrate skill (current_scope issue #45, MVP).
# Self-contained parity harness: replays subject x permission (x record) cells
# through BOTH authorization systems and fails on unexplained divergence.
#
#   bin/rails current_scope_migrate:parity
#
# Reads  config/current_scope_parity.yml            (the exemplar manifest)
# Reads  docs/current_scope_migration/accepted_diffs.yml   (intentional changes)
# Writes docs/current_scope_migration/PARITY.md     (the diff report)
#
# Caveats (stated up front, per the honest contract):
# - Policies needing request context cannot be replayed in-process; list them
#   under `excluded_keys:` in the manifest and verify them by hand.
# - Confidence is only as good as the exemplar matrix in the manifest.
# Deliberately NOT under the engine's current_scope: namespace — this file is
# host-owned migration tooling, and squatting the engine's namespace could
# collide with tasks a future gem version ships.
namespace :current_scope_migrate do
  desc "Diff the old authorization system against current_scope for every manifest cell"
  task parity: :environment do
    manifest_path = Rails.root.join("config/current_scope_parity.yml")
    abort "Missing #{manifest_path} — the skill generates a starter." unless manifest_path.exist?

    manifest = YAML.safe_load_file(manifest_path, aliases: true) || {}
    accepted_path = Rails.root.join("docs/current_scope_migration/accepted_diffs.yml")
    accepted = accepted_path.exist? ? (YAML.safe_load_file(accepted_path) || []) : []
    # The audit contract: every accepted divergence carries a reviewable
    # reason. A reason-less entry could silently wave through a privilege
    # change, so it aborts instead of indexing.
    reasonless = accepted.reject { |d| d["reason"].to_s.strip.length.positive? }
    if reasonless.any?
      abort "accepted_diffs.yml entries missing a reason: " \
            "#{reasonless.map { |d| d.slice('subject', 'key', 'record', 'scope').compact.to_json }.join('; ')}"
    end
    accepted_index = accepted.to_set do |d|
      if d["scope"] # an accepted scope divergence: {subject:, scope: ModelName}
        [ d["subject"], "scope:#{d['scope']}" ].join("|")
      else
        d.values_at("subject", "key", "record").join("|")
      end
    end

    old_system = (manifest["old_system"] || "pundit").to_s
    old_label = { "pundit" => "Pundit", "cancancan" => "CanCanCan",
                  "action_policy" => "Action Policy" }[old_system]
    abort "unknown old_system #{old_system.inspect} (pundit | cancancan | action_policy)" unless old_label

    # Conventional edit->update / new->create aliases, applied for Pundit and
    # Action Policy. CanCanCan resolves its own alias_action chain inside
    # Ability#can?, so it receives the raw action. This file is host-owned
    # after copy — a host with nonstandard aliases edits this hash directly;
    # an unmapped custom action degrades to a visible unanswerable cell.
    aliases = { "edit" => "update", "new" => "create" }
    excluded = (manifest["excluded_keys"] || []).to_set
    key_models = manifest["key_models"] || {}

    # eval is deliberate. The manifest lives in the host's own repo, so anyone
    # who can edit it can equally edit this rake file, the Gemfile, or any
    # other Ruby that CI runs — the YAML is not a lower-privilege boundary,
    # and locators must express factories/scopes ("FactoryBot.create(:admin)",
    # "User.where(...).first!") that a data-only parser cannot. Never feed
    # this manifest from user input or an untrusted source.
    subjects = (manifest["subjects"] || {}).transform_values { |expr| eval(expr) } # rubocop:disable Security/Eval
    records = (manifest["records"] || {}).transform_values { |expr| eval(expr) } # rubocop:disable Security/Eval
    abort "Manifest declares no subjects — add one exemplar per role." if subjects.empty?

    # Best-effort controller-path -> model: "admin/posts#update" -> Post.
    # Override per key via `key_models:` when the guess is wrong.
    model_for = lambda do |key|
      explicit = key_models[key] || key_models[key.split("#").first]
      next explicit.constantize if explicit

      key.split("#").first.split("/").last.classify.safe_constantize
    end

    # Per-system old answer. true/false = an answer; a String = zero coverage
    # for that cell (surfaced in the report, never silently dropped).
    #
    # Pundit: namespaced lookup ("admin/posts" asks Admin::PostPolicy first,
    # falling back to PostPolicy) — the un-namespaced policy would fake parity.
    pundit_answer = lambda do |subject, key, record|
      next "Pundit not loaded (check old_system: in the manifest)" unless defined?(Pundit)

      action = aliases.fetch(key.split("#").last, key.split("#").last)
      model = model_for.call(key)
      target = record || model
      next "no target model (add key_models)" unless target

      namespace = key.split("#").first.split("/")[0..-2].map(&:to_sym)
      lookup = namespace.empty? ? target : namespace + [ target ]
      policy = begin
        Pundit.policy!(subject, lookup)
      rescue Pundit::NotDefinedError
        begin
          namespace.empty? ? nil : Pundit.policy!(subject, target)
        rescue Pundit::NotDefinedError
          nil
        end
      end
      next "no Pundit policy" unless policy
      next "policy lacks ##{action}?" unless policy.respond_to?("#{action}?")

      begin
        policy.public_send("#{action}?")
      rescue StandardError => e
        # A raising policy (nil access on a class-level cell, etc.) is zero
        # coverage for this cell — visible in the report, never a crashed run.
        "raised #{e.class}: #{e.message}"
      end
    end

    # CanCanCan: one Ability, raw action (Ability#can? resolves its own
    # alias_action chain — index/show->read, edit->update, new->create).
    cancancan_answer = lambda do |subject, key, record|
      action = key.split("#").last.to_sym
      model = model_for.call(key)
      target = record || model
      next "no target model (add key_models)" unless target

      # Checked up front, not via rescue: a NameError raised INSIDE a broken
      # Ability must surface as "raised", never masquerade as an absent class
      # (which would zero out every cell and fake a green run).
      next "no Ability class" unless defined?(Ability)

      begin
        Ability.new(subject).can?(action, target)
      rescue StandardError => e
        "raised #{e.class}: #{e.message}"
      end
    end

    # Action Policy: per-model policy, namespaced constant first; apply()
    # resolves alias_rule/default_rule chains the class defines.
    ap_policy_for = lambda do |key, model|
      namespace = key.split("#").first.split("/")[0..-2].map { |seg| seg.camelize }
      [ (namespace + [ "#{model.name}Policy" ]).join("::"), "#{model.name}Policy" ]
        .uniq.filter_map { |name| name.safe_constantize }.first
    end
    action_policy_answer = lambda do |subject, key, record|
      next "ActionPolicy not loaded (check old_system: in the manifest)" unless defined?(ActionPolicy)

      # RAW action, like the CanCanCan branch: apply() itself resolves
      # alias_rule/default_rule chains, so pre-mapping edit->update here
      # would silently answer the wrong rule for a host with a distinct
      # edit? rule and fake parity.
      action = key.split("#").last
      model = model_for.call(key)
      target = record || model
      next "no target model (add key_models)" unless target

      policy_class = ap_policy_for.call(key, model)
      next "no policy class" unless policy_class

      begin
        policy_class.new(target, user: subject).apply(:"#{action}?")
      rescue StandardError => e
        "raised #{e.class}: #{e.message}"
      end
    end

    old_answer = { "pundit" => pundit_answer, "cancancan" => cancancan_answer,
                   "action_policy" => action_policy_answer }.fetch(old_system)

    rows = []
    unanswerable = []
    recordless_models = Set.new
    CurrentScope.catalog.keys.sort.each do |key|
      next if excluded.include?(key)

      model = model_for.call(key)
      record = model && records[model.name]
      recordless_models << model.name if model && record.nil?
      subjects.each do |role_label, subject|
        old_answer_value = old_answer.call(subject, key, record)
        # Record-less cells pass the resolved model so the check represents
        # the TYPED collection gate — the migrated controller will declare
        # current_scope_model per the decision report; omitting it here would
        # fail every scoped collection grant closed and fake a divergence.
        new_answer = CurrentScope.allowed?(key, subject: subject, record: record,
                                           model: record ? nil : model)
        unless [ true, false ].include?(old_answer_value)
          # A cell the old system cannot answer is ZERO coverage, not parity —
          # it must be visible, never dropped. And when current_scope ALLOWS
          # such a cell, that is a potential new privilege (the missing
          # policy/rule was an effective deny): it fails the run unless
          # accepted with a reason.
          record_label = record ? "#{model.name}##{record.id}" : "-"
          cell_id = [ role_label, key, record_label ].join("|")
          unanswerable << { subject: role_label, key: key, record: record_label,
                            reason: old_answer_value, new: new_answer,
                            accepted: accepted_index.include?(cell_id) }
          next
        end
        next if old_answer_value == new_answer

        cell_id = [ role_label, key, record ? "#{model.name}##{record.id}" : "-" ].join("|")
        rows << { subject: role_label, key: key,
                  record: record ? "#{model.name}##{record.id}" : "-",
                  old: old_answer_value, new: new_answer,
                  accepted: accepted_index.include?(cell_id) }
      end
    end

    # Scope parity: policy_scope ids vs scope_for ids. Coverage comes from the
    # manifest's scope_models list (fill it from the inventory's Scope rows) —
    # a scope-bearing model with no record exemplar is UNVERIFIED, not green.
    scope_models = ((manifest["scope_models"] || []) | records.keys)
    scope_unverified = []
    scope_rows = scope_models.flat_map do |model_name|
      record = records[model_name]
      unless record
        scope_unverified << model_name
        next []
      end
      model = record.class
      # Resolve the index key through the same catalog/key_models mapping as
      # the per-cell matrix. No routed index key = nothing to diff against —
      # UNVERIFIED, never a diff on a fabricated key.
      key = CurrentScope.catalog.keys.find { |k| k.end_with?("#index") && model_for.call(k) == model }
      unless key
        scope_unverified << "#{model_name} (no routed #index key resolves to it)"
        next []
      end
      # Per-system old scope. Pundit uses the same namespaced lookup as the
      # cell matrix (Admin::PostPolicy::Scope before PostPolicy::Scope);
      # CanCanCan uses accessible_by; Action Policy applies the policy's
      # relation scope.
      namespace = key.split("#").first.split("/")[0..-2].map(&:to_sym)
      old_scope =
        case old_system
        when "pundit"
          scope_target = namespace.empty? ? model : namespace + [ model ]
          lambda do |subject|
            Pundit.policy_scope!(subject, scope_target)
          rescue Pundit::NotDefinedError
            namespace.empty? ? raise : Pundit.policy_scope!(subject, model)
          end
        when "cancancan"
          ->(subject) { model.accessible_by(Ability.new(subject)) }
        when "action_policy"
          lambda do |subject|
            policy_class = ap_policy_for.call(key, model)
            raise NameError, "no policy class for #{model.name}" unless policy_class

            policy_class.new(model, user: subject)
                        .apply_scope(model.all, type: :active_record_relation)
          end
        end
      begin
        old_scope.call(subjects.values.first)
      rescue Pundit::NotDefinedError, NameError => e
        # No old-side scope = zero coverage for this model — visible,
        # not a silent skip.
        scope_unverified << "#{model_name} (no #{old_label} scope: #{e.class})"
        next []
      rescue StandardError => e
        # A scope needing request context (or otherwise raising) is
        # uncovered, not a crashed run.
        scope_unverified << "#{model_name} (#{old_label} scope raised #{e.class}: #{e.message})"
        next []
      end
      subjects.filter_map do |role_label, subject|
        old_ids = begin
          old_scope.call(subject).pluck(:id).sort
        rescue StandardError => e
          scope_unverified << "#{model_name} × #{role_label} (raised #{e.class})"
          next
        end
        new_ids = CurrentScope.scope_for(subject: subject, model: model, permission: key)
                              .pluck(:id).sort
        next if old_ids == new_ids

        scope_id = [ role_label, "scope:#{model_name}" ].join("|")
        { subject: role_label, model: model_name, old: old_ids, new: new_ids,
          accepted: accepted_index.include?(scope_id) }
      end
    end

    report = Rails.root.join("docs/current_scope_migration/PARITY.md")
    FileUtils.mkdir_p(report.dirname)
    unexplained = rows.reject { |r| r[:accepted] }
    scope_unexplained = scope_rows.reject { |r| r[:accepted] }
    File.write(report, <<~MD)
      # Parity report (#{old_label} → current_scope) — #{Time.current.iso8601}

      Cells diverging: #{rows.size} (accepted: #{rows.count { |r| r[:accepted] }},
      **unexplained: #{unexplained.size}**) ·
      Cells with ZERO coverage (#{old_label} could not answer): #{unanswerable.size}

      | Subject | Key | Record | #{old_label} | current_scope | Accepted |
      |---|---|---|---|---|---|
      #{rows.map { |r| "| #{r[:subject]} | `#{r[:key]}` | #{r[:record]} | #{r[:old]} | #{r[:new]} | #{r[:accepted] ? 'yes' : '**NO**'} |" }.join("\n")}

      ## Unanswerable cells (no coverage — NOT parity)

      These keys were compared against nothing. Resolve each: add key_models,
      add the record exemplar, or verify by hand and move to excluded_keys.
      A cell current_scope ALLOWS here is a potential NEW privilege and fails
      the run until accepted with a reason.

      #{unanswerable.empty? ? 'None.' : unanswerable.map { |u| "- #{u[:subject]} × `#{u[:key]}` × #{u[:record]} — #{u[:reason]}; current_scope says **#{u[:new] ? 'ALLOW ⚠' : 'deny'}**#{u[:accepted] ? ' (accepted)' : u[:new] ? ' **UNEXPLAINED**' : ''}" }.join("\n")}

      ## Scope parity (#{old_label} scope vs scope_for)

      #{scope_rows.empty? ? 'No divergence among covered models.' : scope_rows.map { |r| "- #{r[:subject]} / #{r[:model]}: old=#{r[:old].inspect} scope_for=#{r[:new].inspect}#{r[:accepted] ? ' (accepted)' : ' **UNEXPLAINED**'}" }.join("\n")}

      #{scope_unverified.any? ? "**Scope UNVERIFIED (no record exemplar in the manifest):** #{scope_unverified.join(', ')}" : ''}

      Excluded keys (verified by hand, per the manifest): #{excluded.empty? ? 'none' : excluded.to_a.sort.join(', ')}

      #{if old_system == 'cancancan' && recordless_models.any?
          "**CanCanCan caveat — record-level rules unverified for: " \
          "#{recordless_models.to_a.sort.join(', ')}.** Class-level can? is " \
          "OPTIMISTIC for hash-conditioned rules (it answers \"could act on " \
          "some record\"), so these cells can read as parity while record " \
          "cells diverge — add record exemplars to the manifest."
        elsif old_system == 'action_policy'
          "**Action Policy caveat:** a deny-by-default default_rule makes " \
          "every UNMAPPED key deny on both sides — green cells prove " \
          "agreement, not that the key was consciously mapped; check the " \
          "decision report's coverage."
        end}
    MD

    puts "Parity report: #{report}"
    new_privilege = unanswerable.select { |u| u[:new] && !u[:accepted] }
    if unexplained.any? || scope_unexplained.any? || new_privilege.any?
      abort "PARITY FAILED: #{unexplained.size} unexplained cell(s), " \
            "#{scope_unexplained.size} unexplained scope divergence(s), " \
            "#{new_privilege.size} unanswerable cell(s) current_scope would ALLOW. " \
            "Fix the grants or record the intentional change in accepted_diffs.yml with a reason."
    end
    if unanswerable.any? || scope_unverified.any?
      puts "Parity OK — with #{unanswerable.size} uncovered cell(s) and " \
           "#{scope_unverified.size} unverified scope(s); see the report. " \
           "This is bounded confidence, not proof."
    else
      puts "Parity OK."
    end
  end
end
