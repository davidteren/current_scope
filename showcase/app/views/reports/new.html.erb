<% content_for :title, "New report" %>

<h1>New report</h1>
<p class="mono" style="color: var(--muted); margin-top: -0.75rem;">
  filed by <%= Current.user.email_address %> — the four-eyes rule means you
  won't be able to approve it yourself
</p>

<%= render "form", report: @report, projects: @projects %>

<div class="actions-row">
  <%= link_to "Back to reports", reports_path %>
</div>
