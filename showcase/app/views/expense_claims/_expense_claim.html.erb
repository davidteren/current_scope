<article class="record" id="<%= dom_id expense_claim %>">
  <header>
    <p class="title"><%= expense_claim.description %></p>
    <% if expense_claim.approved? %>
      <span class="stamp stamp--approved <%= "just-stamped" if flash[:notice] == "Expense claim approved." %>">
        Approved
        <small><%= expense_claim.approved_by.email_address %> · <%= expense_claim.approved_at.to_date %></small>
      </span>
    <% else %>
      <span class="stamp stamp--pending">Pending approval</span>
    <% end %>
  </header>
  <dl>
    <dt>No.</dt>
    <dd class="mono"><%= format("%04d", expense_claim.id) %></dd>

    <dt>Amount</dt>
    <dd class="mono"><%= number_to_currency(expense_claim.amount) if expense_claim.amount %></dd>

    <dt>Submitted by</dt>
    <dd class="mono"><%= expense_claim.submitted_by.email_address %></dd>
  </dl>
</article>
