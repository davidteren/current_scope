<article class="record" id="<%= dom_id report %>">
  <header>
    <p class="title"><%= report.title %></p>
    <% if report.approved? %>
      <span class="stamp stamp--approved <%= "just-stamped" if flash[:notice] == "Report approved." %>">
        Approved
        <small><%= report.approved_by.email_address %> · <%= report.approved_at.to_date %></small>
      </span>
    <% else %>
      <span class="stamp stamp--pending">Pending approval</span>
    <% end %>
  </header>
  <dl>
    <dt>No.</dt>
    <dd class="mono"><%= format("%04d", report.id) %></dd>

    <dt>Project</dt>
    <dd><%= report.project.name %></dd>

    <dt>Requested by</dt>
    <dd class="mono"><%= report.requested_by.email_address %></dd>
  </dl>
</article>
