<article class="record" id="<%= dom_id pay_run %>">
  <header>
    <p class="title"><%= pay_run.label %></p>
    <% if pay_run.approved? %>
      <span class="stamp stamp--approved <%= "just-stamped" if flash[:notice] == "Pay run approved." %>">
        Approved
        <small><%= pay_run.approved_by.email_address %> · <%= pay_run.approved_at.to_date %></small>
      </span>
    <% else %>
      <span class="stamp stamp--pending">Pending approval</span>
    <% end %>
  </header>
  <dl>
    <dt>No.</dt>
    <dd class="mono"><%= format("%04d", pay_run.id) %></dd>

    <dt>Period</dt>
    <dd><%= pay_run.period %></dd>

    <dt>Amount</dt>
    <dd class="mono"><%= number_to_currency(pay_run.amount) if pay_run.amount %></dd>

    <dt>Prepared by</dt>
    <dd class="mono"><%= pay_run.prepared_by.email_address %></dd>
  </dl>
</article>
