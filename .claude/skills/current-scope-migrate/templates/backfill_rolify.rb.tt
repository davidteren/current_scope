# frozen_string_literal: true

# Generated by the current-scope-migrate skill (#45 phase 2). REVIEW BEFORE
# RUNNING: every constant below is a decision point. Run in staging first.
#
# Moves WHO HOLDS WHAT from rolify into current_scope rows:
#   global rolify roles (no resource)        -> Role + audited org-wide grant
#   instance-scoped roles (resource present) -> ScopedRoleAssignment
# Grid ticks come from the decision report, not from this migration.
#
# Two go/no-go preflights ABORT before writing anything:
#   1. current_scope allows ONE org-wide role per subject; users holding
#      several global rolify roles need PRECEDENCE to decide (first match
#      wins). Anyone unresolved is listed and the migration stops.
#   2. rolify CLASS-scoped roles (resource_type set, resource_id nil) have no
#      current_scope equivalent — they are listed and the migration stops
#      until you decide (usually: promote to a global role, or grant per
#      record). Delete the abort only after that decision is recorded.
class BackfillCurrentScopeRolesFromRolify < ActiveRecord::Migration[8.1]
  # --- DECISION POINTS ------------------------------------------------------
  SUBJECT_CLASS = "User"
  # Highest first. A user with several GLOBAL rolify roles gets the first of
  # their roles that appears here; a multi-role user with none listed aborts.
  PRECEDENCE = %w[].freeze # e.g. %w[admin manager member]
  FULL_ACCESS_NAMES = %w[].freeze # rolify role names that mean "everything"
  ROLE_NAMES = {}.freeze          # optional pretty names, e.g. { "admin" => "Owner" }
  # grant! REPLACES a subject's org role. Subjects already holding a role that
  # differs from what precedence resolves ABORT unless you flip this after
  # reviewing the listed subjects.
  REPLACE_EXISTING_ROLES = false
  # --------------------------------------------------------------------------

  def up
    subjects = SUBJECT_CLASS.constantize

    class_scoped = ::Role.where.not(resource_type: nil).where(resource_id: nil)
    if class_scoped.exists?
      raise "rolify class-scoped roles have no current_scope equivalent:\n" +
            class_scoped.pluck(:name, :resource_type).map { |n, t| "  #{n} on #{t}" }.join("\n") +
            "\nDecide per role — promote to a global role (add it to the rolify " \
            "data as unscoped, or grant it in §6.2 seeding) or convert to " \
            "per-record grants — then delete this preflight and re-run."
    end

    global = ::Role.where(resource_type: nil, resource_id: nil)

    # One query: every subject's global rolify role names.
    names_by_subject = subjects.joins(:roles).merge(global)
                               .pluck(:id, "roles.name")
                               .group_by(&:first).transform_values { |rows| rows.map(&:last) }

    # ANY unranked role on a multi-role user aborts — a partial PRECEDENCE
    # list must not silently demote (e.g. [admin, member] with only "member"
    # ranked would quietly pick member).
    unresolved = names_by_subject.select do |_id, names|
      names.size > 1 && (names - PRECEDENCE).any?
    end.keys
    if unresolved.any?
      raise "one org-wide role per subject: add these users' roles to PRECEDENCE " \
            "(or merge roles) first:\n" +
            unresolved.map { |id| "  #{SUBJECT_CLASS}##{id}: #{names_by_subject[id].join(', ')}" }.join("\n")
    end

    global.distinct.pluck(:name).each { |name| find_or_align_role!(name) }

    winner_for = lambda do |subject_id|
      names = names_by_subject.fetch(subject_id)
      PRECEDENCE.find { |p| names.include?(p) } || names.first
    end

    # One query for every existing assignment (not one find_by per subject).
    current_role_by_id = CurrentScope::RoleAssignment
                         .where(subject_type: subjects.base_class.name)
                         .joins(:role).pluck(:subject_id, "current_scope_roles.name").to_h

    conflicted = names_by_subject.keys.filter_map do |id|
      current = current_role_by_id[id]
      wanted = role_name(winner_for.call(id))
      "  #{SUBJECT_CLASS}##{id}: holds #{current.inspect}, rolify says #{wanted.inspect}" if
        current && current != wanted
    end
    if conflicted.any?
      unless REPLACE_EXISTING_ROLES
        raise "these subjects already hold a DIFFERENT org role (grant! would " \
              "replace it) — review, then set REPLACE_EXISTING_ROLES = true:\n" +
              conflicted.join("\n")
      end
      # The flag approves whatever conflicts exist AT RUN TIME (staging's
      # reviewed list is not production's) — so the replacements are always
      # printed, never silent.
      say "REPLACING #{conflicted.size} existing role assignment(s):"
      conflicted.each { |c| say c }
    end

    subjects.where(id: names_by_subject.keys).find_each do |subject|
      role = CurrentScope::Role.find_by!(name: role_name(winner_for.call(subject.id)))
      # Audited path: org_role.assigned, source: "bootstrap".
      CurrentScope.grant!(subject, role: role)
    end

    # Instance-scoped rolify rows map 1:1 onto scoped grants. NOTE: direct
    # ScopedRoleAssignment writes are not ledger-recorded (documented engine
    # behavior) — the audit trail for scoped grants starts at cutover.
    ::Role.where.not(resource_type: nil).where.not(resource_id: nil).find_each do |rolify_role|
      cs_role = find_or_align_role!(rolify_role.name)
      holders = subjects.joins(:roles).where(roles: { id: rolify_role.id }).distinct
      holders.find_each do |subject|
        resource = rolify_role.resource
        next if resource.nil? # target row deleted — nothing to grant

        CurrentScope::ScopedRoleAssignment.find_or_create_by!(
          subject: subject, role: cs_role, resource: resource
        )
      end
    end
  end

  def down
    raise ActiveRecord::IrreversibleMigration,
          "role data was copied, not moved — the rolify tables are intact"
  end

  private

  def role_name(value) = ROLE_NAMES.fetch(value, value)

  # find_or_create_by!'s block only runs on CREATE — a pre-seeded role keeping
  # a stale full_access would make FULL_ACCESS_NAMES a dead knob. Fail loud.
  def find_or_align_role!(rolify_name)
    wanted = FULL_ACCESS_NAMES.include?(rolify_name)
    role = CurrentScope::Role.find_or_create_by!(name: role_name(rolify_name)) do |r|
      r.full_access = wanted
    end
    if role.full_access != wanted
      raise "role #{role.name.inspect} already exists with " \
            "full_access=#{role.full_access} but FULL_ACCESS_NAMES says #{wanted} — " \
            "align the constant or the seeded role first"
    end
    role
  end
end
