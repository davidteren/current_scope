<% content_for :title, "Refused" %>

<section class="denied">
  <span class="stamp stamp--denied">Refused</span>

  <% case @denial_reason %>
  <% when :sod_veto %>
    <h1>The gate refused.</h1>
    <p>
      The person who prepared a record can never approve it. This is
      <b>separation of duties</b> — it is not grantable and not configurable,
      and it overrides even full access.
    </p>
  <% when :impersonation_gate %>
    <h1>The gate refused.</h1>
    <p>
      This session is acting-as someone else, and mutations are read-only while
      you do. Stop acting-as to make changes as yourself.
    </p>
  <% else %>
    <h1>The gate refused.</h1>
    <p>Your current role does not grant this action.</p>
    <p class="denied__aside">
      Another visitor in this shared sandbox may have changed the rules — it
      resets soon.
    </p>
  <% end %>

  <p class="denied__actions">
    <%= link_to "Back to the walkthrough", main_app.walkthrough_path, class: "button" %>
    <%= link_to "Home", main_app.root_path %>
  </p>
</section>
