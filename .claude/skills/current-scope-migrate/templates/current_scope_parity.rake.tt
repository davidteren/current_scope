# frozen_string_literal: true

# Generated by the current-scope-migrate skill (current_scope issue #45, MVP).
# Self-contained parity harness: replays subject x permission (x record) cells
# through BOTH authorization systems and fails on unexplained divergence.
#
#   bin/rails current_scope_migrate:parity
#
# Reads  config/current_scope_parity.yml            (the exemplar manifest)
# Reads  docs/current_scope_migration/accepted_diffs.yml   (intentional changes)
# Writes docs/current_scope_migration/PARITY.md     (the diff report)
#
# Caveats (stated up front, per the honest contract):
# - Policies needing request context cannot be replayed in-process; list them
#   under `excluded_keys:` in the manifest and verify them by hand.
# - Confidence is only as good as the exemplar matrix in the manifest.
namespace :current_scope_migrate do
  desc "Diff Pundit answers against current_scope for every manifest cell"
  task parity: :environment do
    manifest_path = Rails.root.join("config/current_scope_parity.yml")
    abort "Missing #{manifest_path} — the skill generates a starter." unless manifest_path.exist?

    manifest = YAML.safe_load_file(manifest_path, aliases: true) || {}
    accepted_path = Rails.root.join("docs/current_scope_migration/accepted_diffs.yml")
    accepted = accepted_path.exist? ? (YAML.safe_load_file(accepted_path) || []) : []
    accepted_index = accepted.to_set { |d| d.values_at("subject", "key", "record").join("|") }

    aliases = { "edit" => "update", "new" => "create" }.merge(manifest["action_aliases"] || {})
    excluded = (manifest["excluded_keys"] || []).to_set
    key_models = manifest["key_models"] || {}

    # eval is deliberate and safe HERE: the expressions are developer-authored
    # record locators in the host's own config/current_scope_parity.yml —
    # the same trust level as the Rakefile running them. Never feed this
    # manifest from user input.
    subjects = (manifest["subjects"] || {}).transform_values { |expr| eval(expr) } # rubocop:disable Security/Eval
    records = (manifest["records"] || {}).transform_values { |expr| eval(expr) } # rubocop:disable Security/Eval
    abort "Manifest declares no subjects — add one exemplar per role." if subjects.empty?

    # Best-effort controller-path -> model: "admin/posts#update" -> Post.
    # Override per key via `key_models:` when the guess is wrong.
    model_for = lambda do |key|
      explicit = key_models[key] || key_models[key.split("#").first]
      next explicit.constantize if explicit

      key.split("#").first.split("/").last.classify.safe_constantize
    end

    pundit_answer = lambda do |subject, key, record|
      action = aliases.fetch(key.split("#").last, key.split("#").last)
      model = model_for.call(key)
      target = record || model
      next "no-policy-target" unless target

      begin
        policy = Pundit.policy!(subject, target)
      rescue Pundit::NotDefinedError
        next "no-policy"
      end
      policy.respond_to?("#{action}?") ? policy.public_send("#{action}?") : "no-method"
    end

    rows = []
    CurrentScope.catalog.keys.sort.each do |key|
      next if excluded.include?(key)

      model = model_for.call(key)
      record = model && records[model.name]
      subjects.each do |role_label, subject|
        old_answer = pundit_answer.call(subject, key, record)
        new_answer = CurrentScope.allowed?(key, subject: subject, record: record)
        next if old_answer == new_answer
        next unless [true, false].include?(old_answer) # unanswerable cells are listed separately

        cell_id = [role_label, key, record ? "#{model.name}##{record.id}" : "-"].join("|")
        rows << { subject: role_label, key: key,
                  record: record ? "#{model.name}##{record.id}" : "-",
                  old: old_answer, new: new_answer,
                  accepted: accepted_index.include?(cell_id) }
      end
    end

    # Scope parity: old policy_scope ids vs scope_for ids, per record exemplar.
    scope_rows = records.filter_map do |model_name, record|
      model = record.class
      key = "#{model.model_name.route_key}#index"
      subjects.filter_map do |role_label, subject|
        old_ids = begin
          Pundit.policy_scope!(subject, model).pluck(:id).sort
        rescue Pundit::NotDefinedError
          next
        end
        new_ids = CurrentScope.scope_for(subject: subject, model: model, permission: key)
                              .pluck(:id).sort
        next if old_ids == new_ids

        { subject: role_label, model: model_name, old: old_ids, new: new_ids }
      end
    end.flatten

    report = Rails.root.join("docs/current_scope_migration/PARITY.md")
    FileUtils.mkdir_p(report.dirname)
    unexplained = rows.reject { |r| r[:accepted] }
    File.write(report, <<~MD)
      # Parity report — #{Time.current.iso8601}

      Cells diverging (excluding cells Pundit cannot answer): #{rows.size}
      Accepted (listed in accepted_diffs.yml): #{rows.count { |r| r[:accepted] }}
      **Unexplained: #{unexplained.size}**

      | Subject | Key | Record | Pundit | current_scope | Accepted |
      |---|---|---|---|---|---|
      #{rows.map { |r| "| #{r[:subject]} | `#{r[:key]}` | #{r[:record]} | #{r[:old]} | #{r[:new]} | #{r[:accepted] ? 'yes' : '**NO**'} |" }.join("\n")}

      ## Scope parity (policy_scope vs scope_for)

      #{scope_rows.empty? ? 'No divergence.' : scope_rows.map { |r| "- #{r[:subject]} / #{r[:model]}: policy_scope=#{r[:old].inspect} scope_for=#{r[:new].inspect}" }.join("\n")}
    MD

    puts "Parity report: #{report}"
    if unexplained.any? || scope_rows.any?
      abort "PARITY FAILED: #{unexplained.size} unexplained cell(s), " \
            "#{scope_rows.size} scope divergence(s). Fix the grants or record " \
            "the intentional change in accepted_diffs.yml with a reason."
    end
    puts "Parity OK."
  end
end
