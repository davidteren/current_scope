<% content_for :title, "Expenses" %>

<div class="page-head">
  <h1>Expenses</h1>
  <% if allowed_to?(:new, ExpenseClaim) %>
    <%= link_to "New claim", new_expense_claim_path, class: "button" %>
  <% end %>
</div>

<% if @records.any? %>
  <table class="ledger" id="expense_claims">
    <thead>
      <tr>
        <th scope="col">No.</th>
        <th scope="col">Description</th>
        <th scope="col" class="optional">Submitted by</th>
        <th scope="col" class="optional">Amount</th>
        <th scope="col">Status</th>
        <th scope="col" class="actions"><span class="visually-hidden">Actions</span></th>
      </tr>
    </thead>
    <tbody>
      <% @records.each do |expense_claim| %>
        <tr id="<%= dom_id expense_claim %>">
          <td class="num"><%= format("%04d", expense_claim.id) %></td>
          <td>
            <% if allowed_to?(:show, expense_claim) %>
              <%= link_to expense_claim.description, expense_claim %>
            <% else %>
              <%= expense_claim.description %>
            <% end %>
          </td>
          <td class="optional mono"><%= expense_claim.submitted_by.email_address %></td>
          <td class="optional mono"><%= number_to_currency(expense_claim.amount) if expense_claim.amount %></td>
          <td>
            <% if expense_claim.approved? %>
              <span class="stamp stamp--approved">Approved</span>
            <% else %>
              <span class="stamp stamp--pending">Pending</span>
            <% end %>
          </td>
          <td class="actions">
            <%= render ApproveButtonComponent.new(record: expense_claim) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="empty">
    <b>No claims you can open.</b> Submit one and it lands here awaiting
    approval — and whoever submits a claim can never be the one to approve it.
  </div>
<% end %>
