<% content_for :title, @record.label %>

<%= render @record %>

<% if !@record.approved? && @record.current_scope_initiator == Current.user %>
  <div class="countersign">
    <span class="glyph">✕✕</span>
    <span>
      <b>Four-eyes rule:</b> you prepared this pay run, so sign-off requires a
      second signatory — even a full-access owner can't stamp their own.
    </span>
  </div>
<% end %>

<div class="actions-row">
  <%= render ApproveButtonComponent.new(record: @record) %>

  <% if allowed_to?(:edit, @record) %>
    <%= link_to "Edit", edit_pay_run_path(@record), class: "button" %>
  <% end %>
  <% if allowed_to?(:destroy, @record) %>
    <%= button_to "Destroy", @record, method: :delete, class: "button--danger",
          data: { turbo_confirm: "Destroy this pay run?" } %>
  <% end %>
  <%= link_to "Back to payroll", pay_runs_path %>
</div>
