<article class="record" id="<%= dom_id contract %>">
  <header>
    <p class="title"><%= contract.title %></p>
    <% if contract.approved? %>
      <span class="stamp stamp--approved <%= "just-stamped" if flash[:notice] == "Contract approved." %>">
        Approved
        <small><%= contract.approved_by.email_address %> · <%= contract.approved_at.to_date %></small>
      </span>
    <% else %>
      <span class="stamp stamp--pending">Pending approval</span>
    <% end %>
  </header>
  <dl>
    <dt>No.</dt>
    <dd class="mono"><%= format("%04d", contract.id) %></dd>

    <dt>Counterparty</dt>
    <dd><%= contract.counterparty %></dd>

    <dt>Amount</dt>
    <dd class="mono"><%= number_to_currency(contract.amount) if contract.amount %></dd>

    <dt>Raised by</dt>
    <dd class="mono"><%= contract.raised_by.email_address %></dd>
  </dl>
</article>
