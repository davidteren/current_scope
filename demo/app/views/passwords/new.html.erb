<% content_for :title, "Reset password" %>

<div class="credentials">
  <h1>Forgot your password?</h1>
  <p class="lede">We'll send reset instructions if the address is on file.</p>

  <%= form_with url: passwords_path do |form| %>
    <div class="field">
      <%= form.label :email_address, "Email address" %>
      <%= form.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username", value: params[:email_address] %>
    </div>
    <%= form.submit "Email reset instructions", class: "button--primary" %>
  <% end %>

  <p class="aux"><%= link_to "Back to sign in", new_session_path %></p>
</div>
